# .env.example — committed template. Copy to .env and fill in real values.
# .env itself is gitignored so secrets never reach the repo.
#
# Usage: cp .env.example .env

# Postgres credentials used by docker-compose and by the Python app.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Host-side port. Set to 5433 to avoid clashing with a local Postgres on 5432.
# Inside Docker, containers always reach each other on 5432.
POSTGRES_PORT=

# GitHub personal access token — needed for enricher.py to fetch PR/issue text.
# Create at: https://github.com/settings/tokens (repo:read scope is enough)
GITHUB_TOKEN=

# OpenAI API key — needed for embedder.py (text-embedding-3-small).
OPENAI_API_KEY=
