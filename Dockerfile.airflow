FROM apache/airflow:2.9.3-python3.10

USER root
RUN apt-get update && apt-get install -y --no-install-recommends gcc libpq-dev && rm -rf /var/lib/apt/lists/*

USER airflow
COPY pyproject.toml /opt/repopulse/pyproject.toml
RUN pip install --no-cache-dir \
    psycopg[binary] \
    requests \
    python-dotenv \
    "openai>=1.0" \
    "langgraph>=0.2" \
    langchain-openai \
    langchain-core \
    "pydantic>=2.0" \
    "langfuse>=3.0" \
    langchain
